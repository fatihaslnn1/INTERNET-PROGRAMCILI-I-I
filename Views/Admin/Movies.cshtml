@model IEnumerable<Proje2.Models.Movie>
@{
    ViewData["Title"] = "Filmler - Admin";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">🎬 Film Yönetimi</h2>
    <a asp-action="AddMovie" class="btn btn-warning">➕ Film Ekle</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Henüz film eklenmemiş.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Fotoğraf</th>
                    <th>Film Adı</th>
                    <th>Yayın Tarihi</th>
                    <th>Eklenme Tarihi</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var movie in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(movie.PhotoPath))
                            {
                                <img src="@movie.PhotoPath" alt="@movie.Title" width="60" height="80" style="object-fit:cover;" class="rounded" />
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="fw-bold">@movie.Title</td>
                        <td>@movie.ReleaseDate.ToString("dd.MM.yyyy")</td>
                        <td>@movie.CreatedAt.ToString("dd.MM.yyyy")</td>
                        <td>
                            <a asp-controller="Home" asp-action="Movie" asp-route-id="@movie.Id"
                               class="btn btn-sm btn-outline-dark me-1" target="_blank">Görüntüle</a>
                            <form asp-action="DeleteMovie" asp-route-id="@movie.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bu filmi silmek istediğinize emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
