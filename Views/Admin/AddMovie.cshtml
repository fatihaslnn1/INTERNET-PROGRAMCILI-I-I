@model Proje2.Models.Movie
@{
    ViewData["Title"] = "Film Ekle";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-dark text-white">
                <h4 class="mb-0">➕ Yeni Film Ekle</h4>
            </div>
            <div class="card-body">
                <form asp-action="AddMovie" asp-controller="Admin" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-bold">Film Adı</label>
                        <input asp-for="Title" class="form-control" placeholder="Film adını girin" required />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ReleaseDate" class="form-label fw-bold">Yayın Tarihi</label>
                        <input asp-for="ReleaseDate" type="date" class="form-control" required />
                        <span asp-validation-for="ReleaseDate" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Summary" class="form-label fw-bold">Film Özeti</label>
                        <textarea asp-for="Summary" class="form-control" rows="5"
                                  placeholder="Filmin kısa özetini yazın..." required></textarea>
                        <span asp-validation-for="Summary" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label for="photo" class="form-label fw-bold">Film Fotoğrafı</label>
                        <input type="file" id="photo" name="photo" class="form-control" accept="image/*" />
                        <small class="text-muted">Desteklenen formatlar: JPG, PNG, GIF, WebP</small>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning fw-bold">Film Ekle</button>
                        <a asp-action="Movies" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
