@model Proje2.Models.Movie
@{
    ViewData["Title"] = Model.Title;
}

<div class="row">
    <div class="col-md-4 mb-4">
        @if (!string.IsNullOrEmpty(Model.PhotoPath))
        {
            <img src="@Model.PhotoPath" class="img-fluid rounded shadow" alt="@Model.Title" />
        }
        else
        {
            <div class="bg-secondary rounded d-flex align-items-center justify-content-center" style="height:400px;">
                <span class="text-white fs-1">🎥</span>
            </div>
        }
    </div>
    <div class="col-md-8">
        <h2 class="fw-bold">@Model.Title</h2>
        <p class="text-muted">📅 Yayın Tarihi: @Model.ReleaseDate.ToString("dd MMMM yyyy")</p>
        <hr />
        <h5>Film Özeti</h5>
        <p>@Model.Summary</p>
    </div>
</div>

<hr class="my-4" />

<div class="row">
    <div class="col-md-8">
        <h4>💬 Yorumlar (@Model.Comments.Count)</h4>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!Model.Comments.Any())
        {
            <p class="text-muted">Bu film için henüz onaylı yorum bulunmuyor. İlk yorumu sen yap!</p>
        }
        else
        {
            @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
            {
                <div class="card mb-3 border-start border-warning border-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <strong>👤 @comment.AuthorName</strong>
                            <small class="text-muted">@comment.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                        </div>
                        <p class="mt-2 mb-0">@comment.Content</p>
                    </div>
                </div>
            }
        }

        <div class="card mt-4 shadow-sm">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">✍️ Yorum Yaz</h5>
            </div>
            <div class="card-body">
                <form asp-controller="Home" asp-action="AddComment" method="post">
                    <input type="hidden" name="movieId" value="@Model.Id" />
                    <div class="mb-3">
                        <label for="authorName" class="form-label fw-bold">İsminiz</label>
                        <input type="text" id="authorName" name="authorName" class="form-control"
                               placeholder="Adınızı girin" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label for="content" class="form-label fw-bold">Yorumunuz</label>
                        <textarea id="content" name="content" class="form-control" rows="4"
                                  placeholder="Film hakkında düşüncelerinizi yazın..." required maxlength="1000"></textarea>
                    </div>
                    <button type="submit" class="btn btn-dark">Yorum Gönder</button>
                </form>
                <small class="text-muted mt-2 d-block">* Yorumunuz admin onayından sonra yayınlanacaktır.</small>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary w-100 mb-3">
            ← Film Listesine Dön
        </a>
    </div>
</div>
