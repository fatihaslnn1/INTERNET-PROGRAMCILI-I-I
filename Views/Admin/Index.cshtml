@{
    ViewData["Title"] = "Admin Panel";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">🛠️ Admin Panel</h2>
    <span class="text-muted">Hoş geldiniz, FatihAslan</span>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-dark shadow h-100">
            <div class="card-body text-center">
                <h1 class="display-4">@ViewBag.MovieCount</h1>
                <p class="mb-0">Toplam Film</p>
            </div>
            <div class="card-footer text-center">
                <a asp-action="Movies" class="text-white">Filmleri Yönet →</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-warning shadow h-100">
            <div class="card-body text-center">
                <h1 class="display-4 text-dark">@ViewBag.PendingCount</h1>
                <p class="mb-0 text-dark">Bekleyen Yorum</p>
            </div>
            <div class="card-footer text-center">
                <a asp-action="Comments" class="text-dark fw-bold">Yorumları Onayla →</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success shadow h-100">
            <div class="card-body text-center">
                <h1 class="display-4">@ViewBag.ApprovedCount</h1>
                <p class="mb-0">Onaylı Yorum</p>
            </div>
            <div class="card-footer text-center">
                <a asp-action="Comments" class="text-white">Tüm Yorumlar →</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <a asp-action="AddMovie" class="btn btn-warning btn-lg w-100">
            ➕ Yeni Film Ekle
        </a>
    </div>
    <div class="col-md-6">
        <a asp-action="Comments" class="btn btn-outline-dark btn-lg w-100">
            💬 Yorumları Onayla
        </a>
    </div>
</div>
